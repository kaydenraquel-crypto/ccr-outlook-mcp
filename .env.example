# Microsoft Entra app (App-only / client credentials flow)
# Register at https://entra.microsoft.com → App registrations
MS_CLIENT_ID=your-client-id-here
MS_CLIENT_SECRET=your-client-secret-value-here
MS_TENANT_ID=your-tenant-id-here

# Default mailbox UPN when a tool call does not specify `mailbox`
DEFAULT_MAILBOX=kris@cocomrepairs.com

# Optional: mock Graph API responses (true/false)
USE_TEST_MODE=false

# Railway assigns PORT automatically in production
# PORT=8080
